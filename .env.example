# ========================================
# RAG ПАЙПЛАЙН - КОНФИГУРАЦИЯ ОКРУЖЕНИЯ
# ========================================
# Скопируйте этот файл в .env и заполните необходимые значения:
#   cp .env.example .env

# ========================================
# ЛОГИРОВАНИЕ
# ========================================
LOG_LEVEL=INFO
LOG_FILE=pipeline.log

# ========================================
# LLM НАСТРОЙКИ (ОБЯЗАТЕЛЬНО!)
# ========================================
# Режим работы LLM: "local" (локальная модель через llama-cpp) или "api" (OpenRouter API)
LLM_MODE=api

# === API РЕЖИМ (OpenRouter) ===
# ВАЖНО: OpenRouter требует ключ даже для бесплатных моделей
# Получите бесплатный ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модель для использования (примеры бесплатных моделей):
# ⭐ РЕКОМЕНДУЕТСЯ:
# - tngtech/tng-r1t-chimera:free (163k context, enhanced tool-calling, reasoning)
# - qwen/qwen3-coder:free (262k context, 480B MoE, специализирована для кода)
# - openai/gpt-oss-20b:free (131k context, 21B, function calling)
#
# Другие бесплатные:
# - tngtech/deepseek-r1t2-chimera:free (163k context, старая версия)
# - openrouter/sherlock-think-alpha (1.8M context, reasoning)
# - meta-llama/llama-3.2-3b-instruct:free (маленькая)
#
# Полный список: https://openrouter.ai/models
LLM_API_MODEL=tngtech/tng-r1t-chimera:free

# Опционально: провайдер для роутинга (grok, openai, anthropic, и т.д.)
LLM_API_ROUTING=

# Параметры API
LLM_API_MAX_WORKERS=10
LLM_API_TIMEOUT=60
LLM_API_RETRIES=3
LLM_API_MAX_TOKENS=150000  # Increased for tng-r1t-chimera (max 163840)

# ========================================
# БАЗЫ ДАННЫХ
# ========================================

# === NEO4J (ГРАФ ЗНАНИЙ) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=code_rag

# === WEAVIATE (ВЕКТОРНАЯ БД) ===
USE_WEAVIATE=true
WEAVIATE_URL=http://localhost:8080

# ========================================
# ОБРАБОТКА ДАННЫХ
# ========================================
# Размер chunk'ов при чтении CSV (маленький для LLM)
CSV_CHUNKSIZE=10

# Размер chunk'ов для подсчета документов (большой для скорости)
CSV_COUNT_CHUNKSIZE=50000

# Количество параллельных воркеров для LLM обработки (1-4)
# ВНИМАНИЕ: требует много VRAM! Для A100 80GB можно 2-3
LLM_PARALLEL_WORKERS=1

# Количество параллельных воркеров для обработки вопросов (1-20)
# Рекомендуется 5-10 для API режима
QUESTION_PROCESSING_WORKERS=20

# Принудительное использование CPU вместо GPU
# FORCE_CPU=false

# ========================================
# RAG УЛУЧШЕНИЯ (ФЛАГИ)
# ========================================
# Reciprocal Rank Fusion (объединение Dense + BM25)
ENABLE_RRF=true

# Context Window (добавление соседних чанков)
ENABLE_CONTEXT_WINDOW=true

# Query Expansion (расширение запроса синонимами)
ENABLE_QUERY_EXPANSION=false

# Metadata Filtering (фильтрация по метаданным)
ENABLE_METADATA_FILTER=true

# Usefulness Filtering (фильтрация по полезности документов)
ENABLE_USEFULNESS_FILTER=true

# Dynamic TOP_K (адаптивный выбор количества результатов)
ENABLE_DYNAMIC_TOP_K=true

# ========================================
# МОДЕЛИ
# ========================================

# === EMBEDDING MODEL ===
# Модель для генерации векторных представлений
# Локальная модель (скачивается автоматически или через: python scripts/download_models.py)
EMBEDDING_MODEL=BAAI/bge-m3

# === RERANKER MODEL ===
# Тип reranker: "cross_encoder" (быстро), "llm" (качественно, медленно), "none"
RERANKER_TYPE=cross_encoder
# Модель для reranking (если RERANKER_TYPE=cross_encoder).
# Локальная модель (скачивается автоматически с HuggingFace при первом запуске).
#
# ⭐ РЕКОМЕНДУЕТСЯ: BAAI/bge-reranker-v2-m3
#    - 568M params, 100+ языков (русский), max_length=8192
#    - SOTA качество на BEIR, хорошо ранжирует длинные блоки кода
#    - VRAM: ~1.2 GB (помещается в любой современный GPU)
#    - Без 8K контекста старый mmarco-MiniLM (max_length=512) "видел"
#      только начало метода — формула в середине файла оставалась
#      непрорезанированной.
#
# Альтернативы (legacy/lighter):
#  - cross-encoder/mmarco-mMiniLMv2-L12-H384-v1 — старый дефолт (80M, 512 ток)
#  - jinaai/jina-reranker-v2-base-multilingual — 278M, 1K ток
#  - mixedbread-ai/mxbai-rerank-large-v2 — 1.5B, дороже
#  - Alibaba-NLP/gte-multilingual-reranker-base — 305M, 8K ток
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# === AGENT MODELS ===
# Code Explorer Agent - итеративное исследование кода
# Рекомендуется: qwen/qwen3-coder:free (262k context, специализирована для кода)
CODE_EXPLORER_MODEL=qwen/qwen3-coder:free

# Query Orchestrator - классификация типов вопросов
ORCHESTRATOR_MODEL=deepseek/deepseek-r1:free

# Analysis Model - для traceback analysis и business agent
# Рекомендуется: tngtech/tng-r1t-chimera:free (enhanced tool-calling)
ANALYSIS_MODEL=tngtech/tng-r1t-chimera:free

# Query Reformulation - переформулирование запросов
QUERY_REFORMULATION_MODEL=tngtech/tng-r1t-chimera:free

# ========================================
# RAG PIPELINE МОДЕЛИ (PRIMARY)
# ========================================
# Каждая роль в RAG-loop'е (search/pipeline/services/) использует свою модель.
# Назначение:
# - QUALITY: оценивает релевантность найденного контекста (SCORE 0..1 + FEEDBACK).
#   Лёгкая задача → можно ставить дешёвую модель.
# - REWRITE: переписывает запрос, если quality_score низкий. Тоже лёгкая.
# - ANSWER:  финальная генерация ответа — самая важная, ставим качественную.
# - CYPHER:  LLM-генерация Neo4j cypher по NL-вопросу (Plan B / cookbook RAG+KG).
#   Если не задана — используется ANSWER модель.
RAG_QUALITY_MODEL=meta-llama/llama-3.3-8b-instruct:free
RAG_REWRITE_MODEL=meta-llama/llama-3.3-8b-instruct:free
RAG_ANSWER_MODEL=meta-llama/llama-3.1-405b-instruct:free
RAG_CYPHER_MODEL=

# ========================================
# RAG PIPELINE МОДЕЛИ (FALLBACK / ОТКАЗОУСТОЙЧИВОСТЬ)
# ========================================
# Если primary endpoint или модель временно недоступны (rate-limit, 5xx,
# таймаут), pipeline автоматически переключается на fallback. Failover
# работает per-role независимо.
#
# Конфигурация делится на ДВЕ части:
#   1) Fallback endpoint  — другой провайдер LLM (например OpenAI direct,
#      когда primary OpenRouter упал). Можно опустить, если хочется
#      оставаться на том же endpoint, но переключиться на другую модель.
#   2) Fallback модели    — резервные модели (на любом из endpoint'ов).
#
# Возможные сценарии:
#  ─ Только fallback модель (одна endpoint, разные модели):
#      RAG_QUALITY_MODEL_FALLBACK=meta-llama/llama-3.1-70b-instruct:free
#      → primary падает → пробуем ту же endpoint, но другую модель.
#
#  ─ Только fallback endpoint (разные endpoint, одинаковая модель):
#      LLM_API_BASE_FALLBACK=https://api.openai.com/v1
#      OPENAI_API_KEY=sk-...
#      → primary падает → пробуем другой endpoint той же моделью.
#
#  ─ И то и другое (полная независимость):
#      LLM_API_BASE_FALLBACK=https://api.openai.com/v1
#      OPENAI_API_KEY=sk-...
#      RAG_ANSWER_MODEL_FALLBACK=gpt-4o
#      → primary падает → другой endpoint, своя модель.
#
# Если ни одно из полей не задано — failover отключён (по умолчанию).

# Fallback endpoint:
LLM_API_BASE_FALLBACK=
# Ключ для fallback endpoint. Можно задать через OPENROUTER_API_KEY_FALLBACK
# или, как алиас (OpenAI direct), через OPENAI_API_KEY.
OPENROUTER_API_KEY_FALLBACK=
OPENAI_API_KEY=

# Fallback модели (опционально):
RAG_QUALITY_MODEL_FALLBACK=
RAG_REWRITE_MODEL_FALLBACK=
RAG_ANSWER_MODEL_FALLBACK=
RAG_CYPHER_MODEL_FALLBACK=

# ========================================
# RAG PIPELINE — GREP ENRICHMENT
# ========================================
# `GrepEnrichTask` (между CollectContextTask и CypherEnrichTask) делает
# точный текстовый поиск идентификаторов из вопроса (`net_pos`,
# `OrderService`, `BASE_URL` и т.п.) по локальным репозиториям. Особенно
# полезно для запросов "как считается X / где определяется Y".
#
# RAG_REPOS_DIR — корень всех индексированных репозиториев. ID нод имеет
# формат "repo:<name>:<rel_path>"; полный путь = $RAG_REPOS_DIR/<name>/<rel_path>.
# Если не задан, GrepEnrichTask пытается достать его из weaviate-индексера.
RAG_REPOS_DIR=

# RAG_RG_PATH — явный путь к ripgrep (override номер 1).
# По умолчанию ищем в порядке:
#   1) shutil.which('rg') — стандартный PATH;
#   2) Bundled-локации VSCode/Cursor (резолвятся автоматически на
#      Windows / macOS / Linux);
#   3) Python fallback (медленнее в ~10×, но работает без зависимостей).
#
# Установка системного ripgrep:
#   Windows : scoop install ripgrep  /  cargo install ripgrep
#   Linux   : apt install ripgrep    /  dnf install ripgrep  /  pacman -S ripgrep
#   macOS   : brew install ripgrep
#
# Узнать путь: `where rg` (Win) / `which rg` (Linux/Mac).
RAG_RG_PATH=

# ========================================
# LANGFUSE (LLM OBSERVABILITY)
# ========================================
# Langfuse - open-source платформа для мониторинга LLM
# Регистрация: https://cloud.langfuse.com или self-hosted
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ========================================
# LANGGRAPH SERVER
# ========================================
# Порог качества контекста для переписывания запроса (0.0 - 1.0)
QUALITY_THRESHOLD=0.6

# ========================================
# TELEGRAM BOT (ОПЦИОНАЛЬНО)
# ========================================
# Токен для Telegram бота
# Получите у @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=

# ========================================
# GRID SEARCH ОПТИМИЗАЦИЯ
# ========================================
# Режим grid search: "test" (5 комбинаций), "quick" (54), "full" (1225)
GRID_SEARCH_MODE=test

# Использовать LLM для оценки в grid search (точнее, но медленнее)
GRID_SEARCH_USE_LLM=true

# ========================================
# ПРОДВИНУТЫЕ ФУНКЦИИ (ОПЦИОНАЛЬНО)
# ========================================
# Parent-Child Chunking (улучшенный чанкинг)
# ENABLE_PARENT_CHILD_CHUNKING=false

# Агентный RAG (итеративный поиск)
# ENABLE_AGENT_RAG=false

# ========================================
# БЫСТРЫЙ СТАРТ
# ========================================
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Получите OPENROUTER_API_KEY на https://openrouter.ai/keys
# 3. Вставьте ключ в OPENROUTER_API_KEY=
# 4. (Опционально) Настройте failover — см. секцию RAG PIPELINE МОДЕЛИ (FALLBACK).
#    Минимум: задать RAG_<role>_MODEL_FALLBACK для критичных ролей.
# 5. (Опционально) Получите TELEGRAM_BOT_TOKEN у @BotFather
# 6. Скачайте локальные модели (embedding + reranker):
#    python scripts/download_models.py
#    Или пропустите - модели скачаются автоматически при первом использовании
# 7. Запустите базы данных: docker-compose up -d
# 8. Проиндексируйте репозиторий:
#    python -m src.core.graph.build_and_index /path/to/repo
# 9. Запустите Telegram бота:
#    python -m src.interfaces.telegram_bot.bot
#    Или API сервер:
#    uvicorn src.interfaces.api.main:app --reload
#
# Документация:
# - README.md - общая информация
# - docs/QUICKSTART.md - быстрый старт
# - docs/MODEL_CONFIGURATION.md - настройка моделей
# - docs/MODEL_RECOMMENDATIONS.md - рекомендации по моделям
